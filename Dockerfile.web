FROM node:22-slim
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY app ./app
COPY build ./build
COPY public ./public
COPY worker ./worker
COPY .openai ./.openai
COPY next.config.ts tsconfig.json vite.config.ts eslint.config.mjs ./
ENV NEXT_PUBLIC_DATA_AGENT_API=http://localhost:8000
RUN npm run build
EXPOSE 3000
CMD ["npm", "run", "start", "--", "--hostname", "0.0.0.0"]
